{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/registrations/:id", "destination": "/api/registrations/[id]" },
    { "source": "/api/photos/:filename",   "destination": "/api/photos/[filename]" },
    { "source": "/api/guest-photos/:filename", "destination": "/api/guest-photos/[filename]" }
  ]
}
