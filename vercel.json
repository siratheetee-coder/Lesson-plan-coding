{
  "version": 2,
  "installCommand": "cd server && npm install",
  "buildCommand": "echo 'no build step'",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/:path*",  "destination": "/api" },
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/healthz",     "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    }
  }
}
