{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Easy ENG Plan (backend + frontend)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "server.js"],
      "cwd": "server",
      "port": 3000
    },
    {
      "name": "Static HTML (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "Static HTML (python http.server)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    }
  ]
}
