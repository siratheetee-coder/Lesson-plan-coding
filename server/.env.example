# ─── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_ORIGIN=http://localhost:5500

# ─── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ───
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_64_bytes
JWT_REFRESH_SECRET=replace_me_with_a_DIFFERENT_long_random_string_64_bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SHORT=7d
JWT_REFRESH_TTL_LONG=30d

# ─── Admin Access ───────────────────────────────────────
# Comma-separated list of emails that auto-become admin on first login.
# These users can access /admin to manage all accounts.
# Example: ADMIN_EMAILS=you@example.com,partner@example.com
ADMIN_EMAILS=

# ─── Google OAuth ───────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (type: Web application)
# Authorized JavaScript origins: http://localhost:5500 (your app origin)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ─── Claude API (added later for AI features) ───────────
ANTHROPIC_API_KEY=

# ─── Database ───────────────────────────────────────────
DB_PATH=./data/app.db.json
