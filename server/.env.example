# ─── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_ORIGIN=http://localhost:5500

# ─── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ───
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_64_bytes
JWT_REFRESH_SECRET=replace_me_with_a_DIFFERENT_long_random_string_64_bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SHORT=7d
JWT_REFRESH_TTL_LONG=30d

# ─── Admin Access ───────────────────────────────────────
# Comma-separated list of emails that auto-become admin on first login.
# These users can access /admin to manage all accounts.
# Example: ADMIN_EMAILS=you@example.com,partner@example.com
ADMIN_EMAILS=

# ─── Google OAuth ───────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (type: Web application)
# Authorized JavaScript origins: http://localhost:5500 (your app origin)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ─── Claude API (added later for AI features) ───────────
ANTHROPIC_API_KEY=

# ─── Database ───────────────────────────────────────────
DB_PATH=./data/app.db.json

# ─── Top-up / Credits ───────────────────────────────────
# Leave OMISE_SECRET_KEY blank → manual top-up mode (admin grants credits manually)
# Set OMISE_SECRET_KEY to enable PromptPay QR payment via Omise/Opn Payments
# Get keys from: https://dashboard.opn.ooo/
OMISE_SECRET_KEY=

# Contact shown to users in manual top-up mode
SUPPORT_LINE=@your_line_id
SUPPORT_EMAIL=support@yourdomain.com
# PromptPay number (mobile / national ID / tax ID) — used to auto-generate QR code
SUPPORT_PROMPTPAY=0812345678
# Display name shown under the QR (your name or shop name)
SUPPORT_PROMPTPAY_NAME=ครูสมชาย
TOPUP_NOTE=สแกน QR เพื่อโอนเงิน แล้วส่งสลิป + email มาที่ LINE
