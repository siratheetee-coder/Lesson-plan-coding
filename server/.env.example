# ─── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_ORIGIN=http://localhost:5500

# ─── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ───
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_64_bytes
JWT_REFRESH_SECRET=replace_me_with_a_DIFFERENT_long_random_string_64_bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SHORT=7d
JWT_REFRESH_TTL_LONG=30d

# ─── Admin Access ───────────────────────────────────────
# Comma-separated list of emails that auto-become admin on first login.
# These users can access /admin to manage all accounts.
# Example: ADMIN_EMAILS=you@example.com,partner@example.com
ADMIN_EMAILS=

# ─── Google OAuth ───────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (type: Web application)
# Authorized JavaScript origins: http://localhost:5500 (your app origin)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ─── Claude API (added later for AI features) ───────────
ANTHROPIC_API_KEY=

# ─── Database ───────────────────────────────────────────
DB_PATH=./data/app.db.json

# ─── Top-up / Credits ───────────────────────────────────
# Leave OMISE_SECRET_KEY blank → manual top-up mode (admin grants credits manually)
# Set OMISE_SECRET_KEY to enable PromptPay QR payment via Omise/Opn Payments
# Get keys from: https://dashboard.opn.ooo/
OMISE_SECRET_KEY=

# Contact shown to users in manual top-up mode (Facebook page link, LINE id, etc.)
SUPPORT_FB=https://www.facebook.com/your_page
SUPPORT_EMAIL=support@yourdomain.com

# ── QR Image: choose ONE of these two methods ──
# Method 1 (RECOMMENDED for Thai QR Merchant): static image URL
# Save your QR image to project root and use relative path
SUPPORT_QR_IMAGE_URL=/qr-payment.png
#
# Method 2: PromptPay number (auto-generates QR with embedded amount)
# Only used if SUPPORT_QR_IMAGE_URL is empty
SUPPORT_PROMPTPAY=
SUPPORT_PROMPTPAY_NAME=

TOPUP_NOTE=สแกน QR เพื่อโอนเงิน แล้วส่งสลิป + email มาที่ LINE

# ─── SlipOK (auto-verify slip & credit user) ────────────
# Sign up at https://slipok.com → get API key + branch ID
# When set, users can upload slip in top-up modal → auto-credited if valid
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=
# Receiving account number to match against the slip (digits only, e.g. 0812345678).
# Used as a security check to ensure the slip was sent to YOUR account.
SLIPOK_RECEIVER_ACCOUNT=
